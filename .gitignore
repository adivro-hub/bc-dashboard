# =====================================================================
# PUBLIC REPO — keep PII out
# =====================================================================
# Raw exports contain customer/passenger names, emails, phone numbers
*.xls
*.xlsx

# jobs.json contains corporate Account Names — exclude
jobs.json

# Full dashboard embeds jobs.json with account names — exclude
dashboard.html

# Tool result captures, etc.
tool-results/

# =====================================================================
# Standard ignores
# =====================================================================
.claude/

# Dev/exploration scripts and ad-hoc CSV exports — not part of the dashboard
peek_*.py
find_*.py
otp_by_service.py
otp_*.csv

# Per-org deploys may keep config.js out of git. We commit it here because
# the anon key is *meant* to be public (security comes from RLS in Postgres,
# enforced server-side), and the org wants the URL to "just work" for the
# team without env-var ceremony.
# config.js
new reports/
__pycache__/
*.pyc
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store

# =====================================================================
# Neon backend / API additions
# =====================================================================
node_modules/
# Schema-discovery dumps from inspect_income_views.py contain DB rows
inspect_income_views.json
# Secret-laden env files — Neon connection string etc.
.env
.env.*
!.env.example
